# Edge-Function-Secrets (NICHT VITE_, NICHT im Client!). Setzen per:
#   supabase secrets set --env-file supabase/functions/.env
# SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY werden von Supabase automatisch injiziert.

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIS=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PRO=

# App-URL (Erfolgs-/Abbruch-Redirect Fallback)
PUBLIC_APP_URL=

# Mail-Provider: console (default, kein Versand) | resend | sendgrid
EMAIL_PROVIDER=console
EMAIL_FROM=LokaleBauernConnect <noreply@lokalebauernconnect.de>
RESEND_API_KEY=
SENDGRID_API_KEY=

# Optional: CORS-Origin einschraenken (sonst *)
CORS_ORIGIN=
